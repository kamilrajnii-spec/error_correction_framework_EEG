        "import pywt\n",
        "import numpy as np\n",
        "\n",
        "def wavelet_denoise(signal, wavelet='db4', level=4):\n",
        "    \"\"\"Applies Discrete Wavelet Transform denoising using soft thresholding.\"\"\"\n",
        "    coeffs = pywt.wavedec(signal, wavelet, level=level)\n",
        "    sigma = np.median(np.abs(coeffs[-1])) / 0.6745\n",
        "    threshold = 0.5 * sigma * np.sqrt(2 * np.log(len(signal)))\n",
        "\n",
        "    denoised_coeffs = [coeffs[0]] + [pywt.threshold(c, threshold, mode='soft') for c in coeffs[1:]]\n",
        "    return pywt.waverec(denoised_coeffs, wavelet)\n",
        "\n",
        "def inject_eye_blink(signal, amp=100):\n",
        "    \"\"\"Injects synthetic eye blink pulses every 1000 samples.\"\"\"\n",
        "    signal = signal.copy()\n",
        "    spacing = 1000\n",
        "    for i in range(len(signal) // spacing):\n",
        "        start = i * spacing\n",
        "        end = min(start + 100, len(signal))\n",
        "        blink = amp * np.exp(-0.5 * ((np.linspace(-1, 1, end - start))**2) / 0.01)\n",
        "        signal[start:end] += blink\n",
        "    return signal"
      ],
